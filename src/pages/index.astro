---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import InfoSection from '../components/InfoSection.astro';
import Footer from '../components/Footer.astro';

const products = [
  { id: 1, name: 'Monstera Deliciosa', price: '$45', care: 'Easy', light: 'Bright Indirect', img: 'https://images.unsplash.com/photo-1614594975525-e45190c55d0b?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
  { id: 2, name: 'Ficus Elastica', price: '$65', care: 'Medium', light: 'Bright', img: 'https://images.unsplash.com/photo-1509423350716-97f9360b4e09?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
  { id: 3, name: 'Calathea Orbifolia', price: '$55', care: 'Hard', light: 'Medium', img: 'https://images.unsplash.com/photo-1600411832986-5a4477b64a1c?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
  { id: 4, name: 'Sansevieria Trifasciata', price: '$30', care: 'Easy', light: 'Any', img: 'https://images.unsplash.com/photo-1592150621744-aca64f48394a?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
  { id: 5, name: 'Aloe Vera', price: '$25', care: 'Easy', light: 'Bright', img: 'https://images.unsplash.com/photo-1596547609652-9cf5d8d76921?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
  { id: 6, name: 'Zamioculcas Zamiifolia', price: '$35', care: 'Easy', light: 'Low', img: 'https://images.unsplash.com/photo-1632207691143-643e2a9a9361?auto=format&fit=crop&q=80&w=800', w: 800, h: 1000 },
];
---

<BaseLayout>
  <a href="#main" class="sr-only sr-only-focusable">Skip to content</a>

  <Header />

  <main id="main">
    <Hero />

    <section id="shop" class="border-b-4 border-primary" aria-labelledby="featured-heading">
      <div class="flex items-center justify-between border-b-4 border-primary px-6 py-8 md:px-12">
        <h2 id="featured-heading" class="text-3xl font-black uppercase tracking-tighter md:text-5xl">Featured Specimens</h2>
        <a href="#shop" class="hidden text-sm font-bold uppercase tracking-widest underline decoration-2 underline-offset-4 hover:text-accent md:inline">View All Plants</a>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3" role="list">
        {products.map((product, index) => (
          <ProductCard product={product} index={index} />
        ))}
      </ul>
    </section>

    <InfoSection />
  </main>

  <Footer />
</BaseLayout>
