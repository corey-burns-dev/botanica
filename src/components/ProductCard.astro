---
import { Image } from 'astro:assets';

interface Props {
  product: {
    id: number;
    name: string;
    price: string;
    care: string;
    light: string;
    img: string;
    w: number;
    h: number;
  };
  index: number;
}

const { product, index } = Astro.props;
---
<li class={`group flex flex-col border-b-4 border-primary md:border-r-4 ${index >= 3 ? 'lg:border-b-0' : ''} ${index === 2 || index === 5 ? 'lg:border-r-0' : ''}`}>
  <article class="flex flex-1 flex-col">
    <div class="relative aspect-[4/5] overflow-hidden bg-white p-6">
      <span class="absolute left-4 top-4 z-10 border-2 border-primary bg-bg px-2 py-1 text-xs font-bold uppercase tracking-widest">{product.care} Care</span>
      <Image
        src={product.img}
        alt={product.name}
        width={product.w}
        height={product.h}
        loading="lazy"
        class="h-full w-full object-cover mix-blend-multiply transition-transform duration-300 group-hover:scale-105"
      />
    </div>
    <div class="flex flex-1 flex-col justify-between border-t-4 border-primary bg-bg p-6">
      <div>
        <h3 class="mb-2 text-xl font-black uppercase tracking-tight">{product.name}</h3>
        <p class="text-sm font-medium text-primary/60">Light: {product.light}</p>
      </div>
      <div class="mt-6 flex items-center justify-between">
        <span class="text-2xl font-black">{product.price}</span>
        <button type="button" class="flex h-10 w-10 items-center justify-center border-2 border-primary transition-colors group-hover:bg-primary group-hover:text-bg" aria-label={`Add ${product.name} to cart`}>+</button>
      </div>
    </div>
  </article>
</li>
