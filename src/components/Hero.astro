---
import { Image } from 'astro:assets';
---
<section class="grid min-h-[85vh] grid-cols-1 border-b-4 border-primary md:grid-cols-2" aria-labelledby="hero-heading">
  <div class="flex flex-col justify-between border-r-0 border-primary p-8 md:border-r-4 md:p-16">
    <div class="space-y-6">
      <span class="inline-flex border-2 border-primary px-3 py-1 text-xs font-bold uppercase tracking-widest text-accent">New Arrivals</span>
      <h1 id="hero-heading" class="text-6xl font-black uppercase leading-[0.9] tracking-tighter sm:text-7xl lg:text-8xl xl:text-9xl">
        Bring<br />Nature<br /><span class="text-accent">Inward.</span>
      </h1>
      <p class="max-w-md border-l-4 border-primary pl-6 text-lg font-medium leading-relaxed tracking-wide text-primary/80">
        Curated architectural plants for the modern sanctuary. Grown with intention, delivered with care.
      </p>
    </div>
    <div class="mt-12 flex gap-4">
      <a href="#shop" class="flex h-16 flex-1 items-center justify-center gap-2 border-4 border-primary bg-primary text-lg font-bold uppercase tracking-widest text-bg transition-all hover:-translate-y-1 hover:shadow-[4px_4px_0px_0px_#8B5A2B]">
        Shop Collection
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
  <div class="relative h-[60vh] overflow-hidden bg-primary md:h-auto">
    <Image
      src="https://images.unsplash.com/photo-1545241047-6083a3684587?auto=format&fit=crop&q=80&w=1600"
      alt="Minimalist interior with large plant"
      width={1600}
      height={1067}
      loading="eager"
      fetchpriority="high"
      class="h-full w-full object-cover opacity-90 mix-blend-luminosity"
    />
    <div class="absolute inset-0 bg-accent/10 mix-blend-multiply" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 border-r-4 border-t-4 border-bg bg-primary p-6">
      <span class="block text-xs font-bold uppercase tracking-widest text-bg">Est. 2026</span>
    </div>
  </div>
</section>
